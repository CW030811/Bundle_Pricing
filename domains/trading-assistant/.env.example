# Demo Trading credentials from:
# OKX -> Trade -> Demo Trading -> Personal Center -> Demo Trading API
OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_PASSPHRASE=

# Production credentials. Do not use these for demo-smoke.
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Optional. Required on networks where OKX resolves to a local proxy fake IP.
# Example for the current macOS system proxy:
OKX_PROXY_URL=http://127.0.0.1:1082
